# ============================================================
# NotesPedia — Environment Configuration
# ============================================================
# For local development, SQLite is used by default.
# For production, switch to Supabase PostgreSQL (see below).
# ============================================================

# Database — SQLite (default for local development)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Database — Supabase PostgreSQL (uncomment for production)
# 1. Also change prisma/schema.prisma provider to "postgresql"
# 2. Then run: bun run db:push && bun run db:generate
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ============================================================
# Supabase (Required for cloud storage)
# ============================================================
# Create a project at https://supabase.com and fill in these values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Authentication
# ============================================================
# IMPORTANT: Change JWT_SECRET to a strong random string in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=notespedia-secret-key-change-in-production
ALLOW_SEED=true

# ============================================================
# Email — Resend (Required for email verification & password reset)
# ============================================================
# Get your API key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@notespedia.com

# ============================================================
# Application
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
